<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
 "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.projectuhost.uhostd</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/project-uhost/bin/uhostd</string>
    <string>--config</string>
    <string>/usr/local/etc/project-uhost/all-in-one.toml</string>
  </array>
  <key>KeepAlive</key>
  <true/>
  <key>RunAtLoad</key>
  <true/>
</dict>
</plist>
